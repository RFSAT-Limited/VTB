<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.rfsat.vtb.capture.CrosshairOverlayView
            android:id="@+id/crosshair"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progressAnalyzing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textSize="12sp"
        android:text="@string/mark_boresight" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="4dp">

        <Button android:id="@+id/btnNudgeLeft" android:text="◀" android:minWidth="0dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp"/>
        <Button android:id="@+id/btnNudgeUp" android:text="▲" android:minWidth="0dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp"/>
        <Button android:id="@+id/btnNudgeDown" android:text="▼" android:minWidth="0dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp"/>
        <Button android:id="@+id/btnNudgeRight" android:text="▶" android:minWidth="0dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp"/>
        <Button android:id="@+id/btnNudgeReset" android:text="Reset" android:minWidth="0dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button android:id="@+id/btnArm" android:text="Arm (Auto-Trigger)"
            android:layout_width="0dp" android:layout_weight="2" android:layout_height="wrap_content"/>
        <EditText android:id="@+id/etSensitivity" android:hint="Sensitivity %"
            android:inputType="number" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
    </LinearLayout>

    <TextView android:id="@+id/tvArmStatus"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingHorizontal="8dp" android:textSize="12sp" android:textStyle="italic"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- Persistent labels: hints vanish once a value is typed, which led
             to the two numeric fields being mistaken for one another. -->
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/tvTargetLabel" android:text="Target (m)" android:textSize="12sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etTargetDistance" android:hint="distance"
                android:inputType="numberDecimal" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:text="FOV (° @1×)" android:textSize="12sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etHorizontalFov" android:hint="10–120"
                android:inputType="numberDecimal" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>
        <!-- Zoom the clip was recorded at. Auto-fills from the live camera;
             for IMPORTED videos (no optics metadata) enter it manually. -->
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:text="Zoom (×)" android:textSize="12sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etZoom" android:hint="1.0"
                android:inputType="numberDecimal" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:layout_marginHorizontal="8dp">
        <TextView android:text="Shot break (s)" android:textSize="12sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <EditText android:id="@+id/etShotBreakSeconds" android:hint="time in clip"
            android:inputType="numberDecimal" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button android:id="@+id/btnRecord" android:text="@string/record"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
        <Button android:id="@+id/btnImportVideo" android:text="@string/import_video"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
        <Button android:id="@+id/btnAnalyze" android:text="@string/analyze_trail"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
    </LinearLayout>

    <include layout="@layout/include_bottom_nav" />
</LinearLayout>
