<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp">
    <TextView android:text="Enter your chronographed average. A second measurement at a different temperature (≥3°C apart) also solves the MV temperature coefficient."
        android:textSize="12sp" android:layout_marginBottom="8dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:text="Measured MV (fps)" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"><EditText android:id="@+id/etChronoMv1" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="0.7" android:layout_height="wrap_content"/><Spinner android:id="@+id/spUChronoMv1" android:layout_width="0dp" android:layout_weight="0.3" android:layout_height="wrap_content"/></LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:text="Temp (°C)" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"><EditText android:id="@+id/etChronoT1" android:inputType="numberDecimal|numberSigned" android:layout_width="0dp" android:layout_weight="0.7" android:layout_height="wrap_content"/><Spinner android:id="@+id/spUChronoT1" android:layout_width="0dp" android:layout_weight="0.3" android:layout_height="wrap_content"/></LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:text="2nd MV (fps, optional)" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"><EditText android:id="@+id/etChronoMv2" android:inputType="numberDecimal" android:layout_width="0dp" android:layout_weight="0.7" android:layout_height="wrap_content"/><Spinner android:id="@+id/spUChronoMv2" android:layout_width="0dp" android:layout_weight="0.3" android:layout_height="wrap_content"/></LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:text="2nd Temp (°C)" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"><EditText android:id="@+id/etChronoT2" android:inputType="numberDecimal|numberSigned" android:layout_width="0dp" android:layout_weight="0.7" android:layout_height="wrap_content"/><Spinner android:id="@+id/spUChronoT2" android:layout_width="0dp" android:layout_weight="0.3" android:layout_height="wrap_content"/></LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
